# =========================================================
#  Server
# =========================================================
# PORT: Local dev port (default 3000)
PORT=3001

# APP_URL: The URL where this applet is hosted.
# AI Studio injects this in production with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3001"

# =========================================================
#  Google Drive OAuth 2.0 (no Firebase)
# =========================================================
# Create a Web Application OAuth Client in:
#   https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins:  http://localhost:3001
# Authorized redirect URI:        http://localhost:3001/api/auth/google/callback
# Enable "Google Drive API" in:   https://console.cloud.google.com/apis/library
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override; defaults to http://localhost:${PORT}/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# =========================================================
#  Browser Configuration
# =========================================================
# PUPPETEER_EXECUTABLE_PATH: Optional override for browser binary
# PLAYWRIGHT_BROWSERS_PATH: Directory where Playwright browsers are stored
PUPPETEER_EXECUTABLE_PATH=
PLAYWRIGHT_BROWSERS_PATH=.browser-cache

# FFmpeg (merge / transcode). On Apple Silicon, npm's ffmpeg-static may be x86_64-only;
# install native ffmpeg and point here: brew install ffmpeg
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# =========================================================
#  Storyblocks configuration
# =========================================================
STORYBLOCKS_COOKIES=
GOOGLE_DRIVE_FOLDER_ID=
